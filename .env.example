# =============================================================
# Copie para .env e ajuste:
#   cp .env.example .env
# No Dokploy, defina estes valores na aba Environment do serviço.
# =============================================================

# ── Domínios (Traefik) ───────────────────────────────────────
# Terminal web da aventura (o filho abre no navegador)
TERMINAL_DOMAIN=vgtux.vsanexus.com
# Painel admin do pai (portal FastAPI)
ADMIN_DOMAIN=adminvgtux.vsanexus.com

# ── Senhas ───────────────────────────────────────────────────
# Senha do portal do pai (dashboard web)
PORTAL_SENHA=troque-esta-senha-do-portal
# Senha do filho — protege o TERMINAL WEB (Basic Auth do ttyd).
# Usuário do login é sempre "jogador".
JOGADOR_SENHA=troque-esta-senha

# ── Minecraft (publicado no host p/ o cliente do jogo) ───────
MC_PORT=25565
# Porta Bedrock (celular) — Geyser abre em UDP. Abra esta porta no firewall da nuvem.
MC_BEDROCK_PORT=19132
# Versão do Paper. Veja: https://papermc.io/downloads/paper
MC_VERSION=1.21.4
MC_RAM_MIN=512M
MC_RAM_MAX=1G

# ── Recursos ─────────────────────────────────────────────────
CONTAINER_MEMORY=1500m

# ── Jornada (compartilhado entre sessao.py e portal) ─────────
SESSAO_MINUTOS=30
LEITURA_MINUTOS=30
ETAPAS_POR_DIA=2
# A partir desta etapa o resumo é no papel + foto (antes é digitado)
FOTO_A_PARTIR=10
