# =============================================================
# Copie para .env e ajuste:
#   cp .env.example .env
# No Dokploy, defina estes valores na aba Environment do serviço.
# =============================================================

# ── Domínios (Traefik) ───────────────────────────────────────
# Painel admin do pai (portal FastAPI)
ADMIN_DOMAIN=adminvgtux.vsanexus.com
# Landing page pública
LANDING_DOMAIN=vgtux.vsanexus.com

# ── Senhas ───────────────────────────────────────────────────
# Senha do portal do pai (dashboard web)
PORTAL_SENHA=troque-esta-senha-do-portal
# Senha do usuário "jogador" (o filho usa no SSH)
JOGADOR_SENHA=troque-esta-senha

# ── SSH / Minecraft (publicados no host) ─────────────────────
# Porta SSH no host (2222 evita conflito com o SSH do host)
SSH_PORT=2222
# Porta do Minecraft no host
MC_PORT=25565

# ── Minecraft ────────────────────────────────────────────────
# Versão do Paper. Veja: https://papermc.io/downloads/paper
MC_VERSION=1.21.4
MC_RAM_MIN=512M
MC_RAM_MAX=1G

# ── Recursos ─────────────────────────────────────────────────
CONTAINER_MEMORY=1500m

# ── Sessão (compartilhado entre sessao.py e portal) ──────────
SESSAO_MINUTOS=30
